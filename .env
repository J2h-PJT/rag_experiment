# PostgreSQL Connection Configuration
# 형식: postgresql+psycopg2://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]
# 사용자 환경에 맞춰 USER, PASSWORD, PORT를 수정하십시오.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/rag_db

# Other Configurations
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
OPENAI_API_KEY=your_api_key_here
